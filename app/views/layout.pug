doctype html
html
  head
    title= title
  body
    if !hideNav
      header
        nav
          a(href="/") Home
          a(href="/languages") Languages
          a(href="/categories") Categories
          a(href="/platform") About
          if currentUser
            a(href="/search") Search
            a(href="/messages") Messages
            a(href="/dashboard") Dashboard
            a(href="/logout") Logout
          else
            a(href="/login") Login
            a(href="/signup") Sign Up

    block content