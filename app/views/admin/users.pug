extends ../layout

block vars
  - var authPage = false
  - var activePage = 'admin-users'

block content
  h2.page-title Manage Users

  p(style='color:var(--muted);font-size:.85rem;margin-bottom:1rem;') Change a user's role, suspend or unsuspend their account, or remove them entirely.

  if !users || users.length === 0
    .info-card
      p(style='color:var(--muted);') No users found.
  else
    table.data-table
      thead
        tr
          th ID
          th Name
          th Username
          th Email
          th Role
          th Status
          th Joined
          th Last Active
          th(style='min-width:340px;') Actions
      tbody
        each user in users
          tr
            td= user.UserID
            td
              a(href=`/users/${user.UserID}`)= user.Full_Name
            td= user.Username
            td(style='font-size:.75rem;')= user.Email
            td
              span.role-badge(class=(user.Role || '').toLowerCase())= user.Role
            td
              if user.Suspended
                span.status-badge.declined Suspended
              else
                span.status-badge.accepted Active
            td(style='font-size:.72rem;color:var(--muted);')= user.Joined_Date
            td(style='font-size:.72rem;color:var(--muted);')= user.Last_Active
            td
              .s-actions(style='gap:.3rem;')
                form(action=`/admin/users/${user.UserID}/role` method='POST' style='display:inline-flex;gap:.25rem;align-items:center;')
                  select(name='role' style='padding:.25rem .4rem;font-size:.72rem;width:auto;')
                    option(value='Learner' selected=user.Role==='Learner') Learner
                    option(value='Teacher' selected=user.Role==='Teacher') Teacher
                    option(value='Admin' selected=user.Role==='Admin') Admin
                  button.btn-sm(type='submit') Update Role
                if user.Suspended
                  form(action=`/admin/users/${user.UserID}/unsuspend` method='POST' style='display:inline')
                    button.btn-sm.btn-outline(type='submit') Unsuspend
                else
                  form(action=`/admin/users/${user.UserID}/suspend` method='POST' style='display:inline')
                    button.btn-sm.btn-outline-red(
                      type='submit'
                      onclick="return confirm('Suspend this user?')"
                    ) Suspend
                form(action=`/admin/users/${user.UserID}/delete` method='POST' style='display:inline')
                  button.btn-sm.btn-danger(
                    type='submit'
                    onclick="return confirm('Are you sure you want to delete this user? This cannot be undone.')"
                  ) Delete
