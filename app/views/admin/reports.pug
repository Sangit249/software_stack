extends ../layout

block vars
  - var authPage = false
  - var activePage = 'admin-reports'

block content
  h2.page-title Manage Reports

  p(style='color:var(--muted);font-size:.85rem;margin-bottom:1rem;') Review user-submitted reports and decide whether to resolve or dismiss them.

  if !reports || reports.length === 0
    .info-card
      p(style='color:var(--muted);') No reports found.
  else
    - var pending = reports.filter(r => r.Status === 'Pending').length
    - var resolved = reports.filter(r => r.Status === 'Resolved').length
    - var dismissed = reports.filter(r => r.Status === 'Dismissed').length
    .stats-grid
      .stat-card
        .stat-number= reports.length
        .stat-label Total
      .stat-card
        .stat-number= pending
        .stat-label Pending
      .stat-card
        .stat-number= resolved
        .stat-label Resolved
      .stat-card
        .stat-number= dismissed
        .stat-label Dismissed

    table.data-table
      thead
        tr
          th ID
          th Reporter
          th Reported User
          th Reason
          th Status
          th Actions
      tbody
        each report in reports
          tr
            td= report.ReportID
            td= report.ReporterName
            td= report.ReportedName
            td(style='max-width:340px;')= report.Reason
            td
              - var s = (report.Status || '').toLowerCase()
              if s === 'resolved'
                span.status-badge.accepted= report.Status
              else if s === 'dismissed'
                span.status-badge.cancelled= report.Status
              else
                span.status-badge.pending= report.Status
            td
              if report.Status === 'Pending'
                .s-actions(style='gap:.3rem;')
                  form(action=`/admin/reports/${report.ReportID}/resolve` method='POST' style='display:inline')
                    button.btn-sm(type='submit') Resolve
                  form(action=`/admin/reports/${report.ReportID}/dismiss` method='POST' style='display:inline')
                    button.btn-sm.btn-outline(type='submit') Dismiss
              else
                span(style='font-size:.72rem;color:var(--muted);')= report.Status
