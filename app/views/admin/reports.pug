extends ../layout

block content
  h2 Manage Reports
  a(href="/admin") Back to Dashboard

  if reports.length === 0
    p No reports found.
  else
    table
      thead
        tr
          th ID
          th Reporter
          th Reported User
          th Reason
          th Status
          th Actions
      tbody
        each report in reports
          tr
            td= report.ReportID
            td= report.ReporterName
            td= report.ReportedName
            td= report.Reason
            td= report.Status
            td
              if report.Status === 'Pending'
                form(action="/admin/reports/" + report.ReportID + "/resolve" method="POST" style="display:inline")
                  button(type="submit") Resolve
                form(action="/admin/reports/" + report.ReportID + "/dismiss" method="POST" style="display:inline; margin-left: 0.5rem")
                  button(type="submit") Dismiss
              else
                span= report.Status